@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;800&display=swap');

:root {
    --glass-bg: rgba(28, 28, 30, 0.7);
    --glass-border: rgba(255, 255, 255, 0.1);
    --safety-red: #FF3B30;
    --safety-orange: #FF9500;
    --safety-blue: #007AFF;
    --safety-dark: #0A0A0B;
    --safety-card: #1C1C1E;
    --transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    --glass-blur: blur(12px);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: var(--safety-dark);
    color: #FFFFFF;
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
    line-height: 1.5;
}

.font-outfit {
    font-family: 'Outfit', sans-serif;
}

.glass {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    transition: var(--transition);
}

.glass:hover {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(40, 40, 45, 0.8);
}

.pulse {
    animation: pulse-animation 2s infinite;
}

@keyframes pulse-animation {
    0% {
        box-shadow: 0 0 0 0px rgba(255, 59, 48, 0.4);
    }

    100% {
        box-shadow: 0 0 0 20px rgba(255, 59, 48, 0);
    }
}

#map {
    height: 100%;
    width: 100%;
    border-radius: 2rem;
    z-index: 10;
}

#fake-call-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, #1c1c1e, #000000);
    z-index: 1000;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 4rem 2rem;
}

.nav-item {
    cursor: pointer;
    transition: var(--transition);
}

.nav-item:hover {
    background: rgba(255, 255, 255, 0.05);
}

.nav-item.active {
    background: rgba(0, 122, 255, 0.15);
    color: var(--safety-blue);
    border-left: 4px solid var(--safety-blue);
}

/* Hide scrollbar but allow scrolling */
::-webkit-scrollbar {
    width: 6px;
    background: transparent;
}

::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.2);
}

/* SOS Alert Overlays */
#sos-alert {
    animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }

    to {
        opacity: 1;
    }
}

.module {
    animation: slideUp 0.5s ease-out;
}

@keyframes slideUp {
    from {
        transform: translateY(20px);
        opacity: 0;
    }

    to {
        transform: translateY(0);
        opacity: 1;
    }
}

/* Animations */
@keyframes bounce-slow {

    0%,
    100% {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-10px);
    }
}

.animate-bounce-slow {
    animation: bounce-slow 4s infinite ease-in-out;
}

/* Hide navigation on blackout */
#blackout-screen:not(.hidden)~aside,
#blackout-screen:not(.hidden)~main,
#blackout-screen:not(.hidden)~.lg\:hidden {
    display: none !important;
}

/* Utility for Lucide integration if needed */
.lucide {
    stroke-width: 2px;
}

/* Report transition */
.report-item {
    transition: var(--transition);
}

.report-item:hover {
    transform: translateX(10px);
    border-color: rgba(255, 255, 255, 0.2);
}
